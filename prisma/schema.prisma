generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model AI_Recommendations {
  RecommendationId Int       @id(map: "PK__AI_Recom__AA15BEE42B0CD4C2") @default(autoincrement())
  UserId           Int
  ProductId        Int
  ConfidenceScore  Float?
  Reason           String?   @db.NVarChar(500)
  CreatedAt        DateTime? @default(dbgenerated("sysdatetime()"), map: "DF__AI_Recomm__Creat__656C112C")
  Products         Products  @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK__AI_Recomm__Produ__14270015")
  Users            Users     @relation(fields: [UserId], references: [UserId], onUpdate: NoAction, map: "FK__AI_Recomm__UserI__1332DBDC")
}

model CartItems {
  CartItemId      Int             @id(map: "PK__CartItem__488B0B0A61200564") @default(autoincrement())
  CartId          Int
  Quantity        Int
  VariantId       Int
  Carts           Carts           @relation(fields: [CartId], references: [CartId], onDelete: Cascade, onUpdate: NoAction, map: "FK_CartItem_Cart")
  ProductVariants ProductVariants @relation(fields: [VariantId], references: [VariantId], onUpdate: NoAction, map: "FK_CartItem_Variant")

  @@unique([CartId, VariantId], map: "UQ_Cart_Variant")
}

model Carts {
  CartId    Int         @id(map: "PK__Carts__51BCD7B7941905E0") @default(autoincrement())
  UserId    Int         @unique(map: "UQ__Carts__1788CC4D0690DFBB")
  CreatedAt DateTime?   @default(dbgenerated("sysdatetime()"), map: "DF__Carts__CreatedAt__66603565")
  CartItems CartItems[]
  Users     Users       @relation(fields: [UserId], references: [UserId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Cart_User")
}

model Categories {
  CategoryId       Int          @id(map: "PK__Categori__19093A0B3054E42B") @default(autoincrement())
  CategoryName     String       @db.NVarChar(150)
  ParentId         Int?
  IsActive         Boolean?     @default(true, map: "DF__Categorie__IsAct__6754599E")
  Categories       Categories?  @relation("CategoriesToCategories", fields: [ParentId], references: [CategoryId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Category_Parent")
  other_Categories Categories[] @relation("CategoriesToCategories")
  Products         Products[]
}

model Conversations {
  ConversationId                         Int        @id(map: "PK__Conversa__C050D877DC9663C1") @default(autoincrement())
  ClientId                               Int
  ShopOwnerId                            Int
  CreatedAt                              DateTime?  @default(dbgenerated("sysdatetime()"), map: "DF__Conversat__Creat__68487DD7")
  Users_Conversations_ClientIdToUsers    Users      @relation("Conversations_ClientIdToUsers", fields: [ClientId], references: [UserId], onUpdate: NoAction, map: "FK__Conversat__Clien__17F790F9")
  Users_Conversations_ShopOwnerIdToUsers Users      @relation("Conversations_ShopOwnerIdToUsers", fields: [ShopOwnerId], references: [UserId], onUpdate: NoAction, map: "FK__Conversat__ShopO__18EBB532")
  Messages                               Messages[]
}

model Invoices {
  InvoiceId      Int       @id(map: "PK__Invoices__D796AAB5E31BD6AF") @default(autoincrement())
  OrderId        Int       @unique(map: "UQ__Invoices__C3905BCECEE59D95")
  InvoiceNumber  String    @unique(map: "UQ__Invoices__D776E981ED8D49BC") @db.NVarChar(50)
  IssueDate      DateTime? @default(dbgenerated("sysdatetime()"), map: "DF__Invoices__IssueD__693CA210")
  TotalAmount    Decimal   @db.Decimal(18, 2)
  BillingName    String    @db.NVarChar(150)
  BillingPhone   String?   @db.NVarChar(20)
  BillingAddress String    @db.NVarChar(300)
  PaymentId      Int
  Orders         Orders    @relation(fields: [OrderId], references: [OrderId], onUpdate: NoAction, map: "FK__Invoices__OrderI__29221CFB")
  Payments       Payments  @relation(fields: [PaymentId], references: [PaymentId], onUpdate: NoAction, map: "FK__Invoices__Paymen__2A164134")
}

model Messages {
  MessageId      Int           @id(map: "PK__Messages__C87C0C9CE1B45061") @default(autoincrement())
  ConversationId Int
  SenderId       Int
  MessageContent String        @db.NVarChar(Max)
  SentAt         DateTime?     @default(dbgenerated("sysdatetime()"), map: "DF__Messages__SentAt__6A30C649")
  Conversations  Conversations @relation(fields: [ConversationId], references: [ConversationId], onDelete: Cascade, onUpdate: NoAction, map: "FK__Messages__Conver__1CBC4616")
  Users          Users         @relation(fields: [SenderId], references: [UserId], onUpdate: NoAction, map: "FK__Messages__Sender__1DB06A4F")
}

model Notifications {
  NotificationId Int       @id(map: "PK__Notifica__20CF2E127D4A71C9") @default(autoincrement())
  UserId         Int
  Title          String?   @db.NVarChar(200)
  Content        String?   @db.NVarChar(Max)
  IsRead         Boolean?  @default(false, map: "DF__Notificat__IsRea__6B24EA82")
  CreatedAt      DateTime? @default(dbgenerated("sysdatetime()"), map: "DF__Notificat__Creat__6C190EBB")
  Users          Users     @relation(fields: [UserId], references: [UserId], onDelete: Cascade, onUpdate: NoAction, map: "FK__Notificat__UserI__22751F6C")
}

model OrderItems {
  OrderItemId     Int             @id(map: "PK__OrderIte__57ED068169698070") @default(autoincrement())
  OrderId         Int
  Quantity        Int
  UnitPrice       Decimal         @db.Decimal(18, 2)
  VariantId       Int
  Orders          Orders          @relation(fields: [OrderId], references: [OrderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_OrderItem_Order")
  ProductVariants ProductVariants @relation(fields: [VariantId], references: [VariantId], onUpdate: NoAction, map: "FK_OrderItem_Variant")
}

model Orders {
  OrderId         Int             @id(map: "PK__Orders__C3905BCF9D97EFF6") @default(autoincrement())
  UserId          Int
  StoreId         Int
  TotalAmount     Decimal         @db.Decimal(18, 2)
  OrderStatus     String          @db.NVarChar(50)
  PaymentStatus   String          @db.NVarChar(50)
  ShippingAddress String          @db.NVarChar(300)
  CreatedAt       DateTime?       @default(dbgenerated("sysdatetime()"), map: "DF__Orders__CreatedA__6D0D32F4")
  UpdatedAt       DateTime?
  AddressId       Int?
  Invoices        Invoices?
  OrderItems      OrderItems[]
  UserAddresses   UserAddresses?  @relation(fields: [AddressId], references: [AddressId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Order_Address")
  Stores          Stores          @relation(fields: [StoreId], references: [StoreId], onUpdate: NoAction, map: "FK_Order_Store")
  Users           Users           @relation(fields: [UserId], references: [UserId], onUpdate: NoAction, map: "FK_Order_User")
  OrderVouchers   OrderVouchers[]
  Payments        Payments[]
}

model OrderVouchers {
  OrderVoucherId Int      @id(map: "PK__OrderVou__5B3AFED46736D2FC") @default(autoincrement())
  OrderId        Int
  VoucherId      Int
  Orders         Orders   @relation(fields: [OrderId], references: [OrderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_OrderVoucher_Order")
  Vouchers       Vouchers @relation(fields: [VoucherId], references: [VoucherId], onUpdate: NoAction, map: "FK_OrderVoucher_Voucher")
}

model Payments {
  PaymentId          Int                 @id(map: "PK__Payments__9B556A38CD8EF204") @default(autoincrement())
  OrderId            Int
  PaymentMethod      String              @db.NVarChar(50)
  TransactionCode    String?             @db.NVarChar(150)
  Amount             Decimal             @db.Decimal(18, 2)
  Status             String?             @db.NVarChar(50)
  PaymentDate        DateTime?
  PaymentMethodId    Int?
  Invoices           Invoices[]
  Orders             Orders              @relation(fields: [OrderId], references: [OrderId], onDelete: Cascade, onUpdate: NoAction, map: "FK_Payment_Order")
  UserPaymentMethods UserPaymentMethods? @relation(fields: [PaymentMethodId], references: [PaymentMethodId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Payment_UserMethod")
}

model ProductImages {
  ImageId   Int      @id(map: "PK__ProductI__7516F70CD47DDD0D") @default(autoincrement())
  ProductId Int
  ImageUrl  String   @db.NVarChar(500)
  Products  Products @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade, onUpdate: NoAction, map: "FK_ProductImage_Product")
}

model Products {
  ProductId          Int                  @id(map: "PK__Products__B40CC6CD70D8D499") @default(autoincrement())
  StoreId            Int
  CategoryId         Int?
  ProductName        String               @db.NVarChar(200)
  Description        String?              @db.NVarChar(Max)
  Price              Decimal              @db.Decimal(18, 2)
  ThumbnailUrl       String?              @db.NVarChar(500)
  IsActive           Boolean?             @default(true, map: "DF__Products__IsActi__6E01572D")
  IsDeleted          Boolean?             @default(false, map: "DF__Products__IsDele__6EF57B66")
  ApprovalStatus     String               @default("PENDING", map: "DF__Products__Approv__6FE99F9F") @db.NVarChar(20)
  RejectReason       String?              @db.NVarChar(500)
  ReviewedBy         Int?
  ReviewedAt         DateTime?
  CreatedAt          DateTime?            @default(dbgenerated("sysdatetime()"), map: "DF__Products__Create__70DDC3D8")
  UpdatedAt          DateTime?
  AI_Recommendations AI_Recommendations[]
  ProductImages      ProductImages[]
  Categories         Categories?          @relation(fields: [CategoryId], references: [CategoryId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Product_Category")
  Users              Users?               @relation(fields: [ReviewedBy], references: [UserId], onDelete: NoAction, onUpdate: NoAction, map: "FK_Product_ReviewedBy_User")
  Stores             Stores               @relation(fields: [StoreId], references: [StoreId], onUpdate: NoAction, map: "FK_Product_Store")
  ProductTryHistory  ProductTryHistory[]
  ProductVariants    ProductVariants[]
  VoucherProducts    VoucherProducts[]
}

model ProductTryHistory {
  TryId       Int       @id(map: "PK__ProductT__BBBDD7EE01E31ECD") @default(autoincrement())
  UserId      Int
  ProductId   Int
  TryImageUrl String?   @db.NVarChar(500)
  CreatedAt   DateTime? @default(dbgenerated("sysdatetime()"), map: "DF__ProductTr__Creat__71D1E811")
  Products    Products  @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK__ProductTr__Produ__0F624AF8")
  Users       Users     @relation(fields: [UserId], references: [UserId], onUpdate: NoAction, map: "FK__ProductTr__UserI__0E6E26BF")
}

model Stores {
  StoreId     Int        @id(map: "PK__Stores__3B82F1010A452B1B") @default(autoincrement())
  OwnerId     Int        @unique(map: "UQ__Stores__819385B9F5DCF6CD")
  StoreName   String     @db.NVarChar(150)
  Description String?    @db.NVarChar(Max)
  LogoUrl     String?    @db.NVarChar(500)
  IsActive    Boolean?   @default(true, map: "DF__Stores__IsActive__72C60C4A")
  IsDeleted   Boolean?   @default(false, map: "DF__Stores__IsDelete__73BA3083")
  CreatedAt   DateTime?  @default(dbgenerated("sysdatetime()"), map: "DF__Stores__CreatedA__74AE54BC")
  Orders      Orders[]
  Products    Products[]
  Users       Users      @relation(fields: [OwnerId], references: [UserId], onUpdate: NoAction, map: "FK_Store_User")
  Vouchers    Vouchers[]
}

model Users {
  UserId                                         Int                  @id(map: "PK__Users__1788CC4C28715DA9") @default(autoincrement())
  FullName                                       String               @db.NVarChar(150)
  Email                                          String               @unique(map: "UQ__Users__A9D1053468DA8C67") @db.NVarChar(150)
  PasswordHash                                   String?              @db.NVarChar(255)
  Phone                                          String?              @db.NVarChar(20)
  AvatarUrl                                      String?              @db.NVarChar(500)
  Role                                           String               @db.NVarChar(20)
  IsActive                                       Boolean?             @default(true, map: "DF__Users__IsActive__797309D9")
  IsDeleted                                      Boolean?             @default(false, map: "DF__Users__IsDeleted__7A672E12")
  CreatedAt                                      DateTime?            @default(dbgenerated("sysdatetime()"), map: "DF__Users__CreatedAt__7B5B524B")
  UpdatedAt                                      DateTime?
  AuthProvider                                   String               @default("local", map: "DF__Users__AuthProvi__7C4F7684") @db.NVarChar(20)
  ProviderId                                     String?              @db.NVarChar(255)
  DateOfBirth                                    DateTime?            @db.Date
  Gender                                         String?              @db.NVarChar(10)
  AI_Recommendations                             AI_Recommendations[]
  Carts                                          Carts?
  Conversations_Conversations_ClientIdToUsers    Conversations[]      @relation("Conversations_ClientIdToUsers")
  Conversations_Conversations_ShopOwnerIdToUsers Conversations[]      @relation("Conversations_ShopOwnerIdToUsers")
  Messages                                       Messages[]
  Notifications                                  Notifications[]
  Orders                                         Orders[]
  Products                                       Products[]
  ProductTryHistory                              ProductTryHistory[]
  Stores                                         Stores?
  UserAddresses                                  UserAddresses[]
  UserPaymentMethods                             UserPaymentMethods[]
}

model Vouchers {
  VoucherId        Int               @id(map: "PK__Vouchers__3AEE7921761840EC") @default(autoincrement())
  StoreId          Int
  Code             String            @unique(map: "UQ__Vouchers__A25C5AA72A481FF5") @db.NVarChar(50)
  DiscountPercent  Int?
  Quantity         Int
  ExpiredDate      DateTime?
  IsActive         Boolean?          @default(true, map: "DF__Vouchers__IsActi__7D439ABD")
  MinOrderValue    Decimal?          @default(0, map: "DF__Vouchers__MinOrd__31B762FC") @db.Decimal(18, 2)
  MaxDiscountValue Decimal?          @db.Decimal(18, 2)
  ApplyType        String?           @default("ALL", map: "DF__Vouchers__ApplyT__32AB8735") @db.NVarChar(20)
  OrderVouchers    OrderVouchers[]
  VoucherProducts  VoucherProducts[]
  Stores           Stores            @relation(fields: [StoreId], references: [StoreId], onUpdate: NoAction, map: "FK_Voucher_Store")
}

model UserAddresses {
  AddressId     Int       @id(map: "PK__UserAddr__091C2AFB828954E1") @default(autoincrement())
  UserId        Int
  FullName      String    @db.NVarChar(150)
  Phone         String    @db.NVarChar(20)
  Province      String    @db.NVarChar(100)
  District      String    @db.NVarChar(100)
  Ward          String    @db.NVarChar(100)
  DetailAddress String    @db.NVarChar(300)
  IsDefault     Boolean?  @default(false, map: "DF__UserAddre__IsDef__75A278F5")
  CreatedAt     DateTime? @default(dbgenerated("sysdatetime()"), map: "DF__UserAddre__Creat__76969D2E")
  Orders        Orders[]
  Users         Users     @relation(fields: [UserId], references: [UserId], onDelete: Cascade, onUpdate: NoAction, map: "FK__UserAddre__UserI__51300E55")
}

model UserPaymentMethods {
  PaymentMethodId Int        @id(map: "PK__UserPaym__DC31C1D338849896") @default(autoincrement())
  UserId          Int
  Type            String     @db.NVarChar(50)
  Provider        String?    @db.NVarChar(50)
  AccountNumber   String?    @db.NVarChar(100)
  CardHolderName  String?    @db.NVarChar(150)
  IsDefault       Boolean?   @default(false, map: "DF__UserPayme__IsDef__778AC167")
  CreatedAt       DateTime?  @default(dbgenerated("sysdatetime()"), map: "DF__UserPayme__Creat__787EE5A0")
  Payments        Payments[]
  Users           Users      @relation(fields: [UserId], references: [UserId], onDelete: Cascade, onUpdate: NoAction, map: "FK__UserPayme__UserI__55F4C372")
}

model ProductVariants {
  VariantId  Int          @id(map: "PK__ProductV__0EA23384E9BBD6EE") @default(autoincrement())
  ProductId  Int
  Size       String       @db.NVarChar(10)
  Color      String?      @db.NVarChar(50)
  Stock      Int
  Price      Decimal?     @db.Decimal(18, 2)
  CartItems  CartItems[]
  OrderItems OrderItems[]
  Products   Products     @relation(fields: [ProductId], references: [ProductId], onUpdate: NoAction, map: "FK_ProductVariant_Product")

  @@unique([ProductId, Size, Color], map: "UQ_Product_Size_Color")
}

model VoucherProducts {
  VoucherId Int
  ProductId Int
  Products  Products @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade, onUpdate: NoAction, map: "FK_VoucherProducts_Product")
  Vouchers  Vouchers @relation(fields: [VoucherId], references: [VoucherId], onDelete: Cascade, onUpdate: NoAction, map: "FK_VoucherProducts_Voucher")

  @@id([VoucherId, ProductId], map: "PK_VoucherProducts")
}
